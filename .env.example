# ──────────────────────────────────────────────────────────────────────────────
# BeloAuto — root .env.example
# Copy to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
#
# These variables are read by docker-compose (docker/docker-compose.yml).
# App-specific variables live in apps/backend/.env and apps/bff/.env.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL — passwords for the two DB roles provisioned by docker/init-db.sh.
# docker-compose passes these into the postgres container on first start.
# Safe local defaults are provided as fallbacks in docker-compose.yml; set
# real values here so they are consistent across the stack.
DB_MIGRATOR_PASSWORD=beloauto_migrator
DB_APP_PASSWORD=beloauto_app

# GCP Pub/Sub (emulator for local dev)
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=beloauto-local

# GCS (fake-gcs-server for local dev)
GCS_EMULATOR_HOST=http://localhost:4443
GCS_BUCKET_NAME=beloauto-local

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string-in-production-environments
JWT_EXPIRES_IN=7d

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3002/v1/auth/google/callback

# BFF
BACKEND_INTERNAL_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000
CRON_SECRET=change-me-to-a-random-32-char-string-for-cron-endpoints

# App
NODE_ENV=development
