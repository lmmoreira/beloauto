NODE_ENV=development
PORT=3001

# PostgreSQL — use separate fields (never a single DATABASE_URL) to avoid
# URL-parsing issues with passwords that contain special characters.
DB_HOST=localhost
DB_PORT=5432
DB_USER=beloauto
DB_PASSWORD=beloauto
DB_NAME=beloauto

# Platform admin — generate with: openssl rand -hex 32
PLATFORM_ADMIN_KEY=change-me-generate-with-openssl-rand-hex-32

# GCP Pub/Sub (emulator for local dev)
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=beloauto-local
# After this many nacks the adapter routes the message to the dead-letter topic
PUBSUB_MAX_DELIVERY_ATTEMPTS=5
# Set false in staging/prod — Terraform owns all Pub/Sub resources there; true only for local dev
PUBSUB_AUTO_CREATE=true

# GCS (fake-gcs-server for local dev)
GCS_EMULATOR_HOST=http://localhost:4443
GCS_BUCKET_NAME=beloauto-local

# Email / Notification
# EMAIL_ADAPTER=mailhog  → uses MailHog (default for local dev; SENDGRID_API_KEY not required)
# EMAIL_ADAPTER=sendgrid → uses SendGrid (staging/prod; SENDGRID_API_KEY required)
EMAIL_ADAPTER=mailhog
EMAIL_FROM=noreply@beloauto.com.br  # must be verified in SendGrid Sender Authentication before staging emails work
SMTP_HOST=localhost
SMTP_PORT=1025
# SENDGRID_API_KEY=SG.xxxx  # required only when EMAIL_ADAPTER=sendgrid

# Frontend URL (used to build activation links in emails)
FRONTEND_URL=http://localhost:3000
