# BFF — Dev Login (M115-S02)
# Quick token acquisition for local development — bypasses Google OAuth.
#
# Prerequisites:
#   1. pnpm infra:up
#   2. pnpm --filter @beloauto/backend run migration:run
#   3. pnpm --filter @beloauto/backend run dev   (port 3001)
#   4. pnpm --filter @beloauto/bff run dev       (port 3002)
#   5. ENABLE_DEV_AUTH=true in apps/bff/.env.local
#
# Usage: run the login request for the persona you need, then use the
# captured {{xxxLogin.response.body.accessToken}} in subsequent requests
# within this file, or copy the token to another file's variable.
#
# Guard: returns 403 if ENABLE_DEV_AUTH != "true" or NODE_ENV == "production".

@bffUrl = {{bffUrl}}
@tenantSlug = lavacar-bh
@managerEmail = admin@lavacar.com.br
@staffEmail = staff@lavacar.com.br
@customerEmail = joao@gmail.com

# ─────────────────────────────────────────────────────────────────────────────
# Login as Manager (STAFF table, role=MANAGER)
# ─────────────────────────────────────────────────────────────────────────────

###
# @name managerLogin
POST {{bffUrl}}/v1/auth/dev-login
Content-Type: application/json

{
  "email": "{{managerEmail}}",
  "tenantSlug": "{{tenantSlug}}",
  "type": "staff"
}

@managerToken = {{managerLogin.response.body.accessToken}}

# ─────────────────────────────────────────────────────────────────────────────
# Login as Staff (STAFF table, role=STAFF)
# ─────────────────────────────────────────────────────────────────────────────

###
# @name staffLogin
POST {{bffUrl}}/v1/auth/dev-login
Content-Type: application/json

{
  "email": "{{staffEmail}}",
  "tenantSlug": "{{tenantSlug}}",
  "type": "staff"
}

@staffToken = {{staffLogin.response.body.accessToken}}

# ─────────────────────────────────────────────────────────────────────────────
# Login as Customer (find-or-create; idempotent)
# ─────────────────────────────────────────────────────────────────────────────

###
# @name customerLogin
POST {{bffUrl}}/v1/auth/dev-login
Content-Type: application/json

{
  "email": "{{customerEmail}}",
  "tenantSlug": "{{tenantSlug}}",
  "type": "customer"
}

@customerToken = {{customerLogin.response.body.accessToken}}

# ─────────────────────────────────────────────────────────────────────────────
# Sanity check — token accepted by a real endpoint
# ─────────────────────────────────────────────────────────────────────────────

###
GET {{bffUrl}}/v1/services
Authorization: Bearer {{managerToken}}
X-Tenant-Slug: {{tenantSlug}}

# ─────────────────────────────────────────────────────────────────────────────
# ERROR CASES
# ─────────────────────────────────────────────────────────────────────────────

###
# 403 — ENABLE_DEV_AUTH not set or false
POST {{bffUrl}}/v1/auth/dev-login
Content-Type: application/json

{
  "email": "{{managerEmail}}",
  "tenantSlug": "{{tenantSlug}}",
  "type": "staff"
}

###
# 400 — invalid email
POST {{bffUrl}}/v1/auth/dev-login
Content-Type: application/json

{
  "email": "not-an-email",
  "tenantSlug": "{{tenantSlug}}",
  "type": "staff"
}

###
# 400 — invalid type
POST {{bffUrl}}/v1/auth/dev-login
Content-Type: application/json

{
  "email": "{{managerEmail}}",
  "tenantSlug": "{{tenantSlug}}",
  "type": "admin"
}
